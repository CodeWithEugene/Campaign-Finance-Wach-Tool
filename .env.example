# Public site URL (for share previews / Open Graph; optional, defaults to Vercel URL)
# NEXT_PUBLIC_APP_URL=https://campaign-finance-wach-tool.vercel.app

# Convex (required for map, reports, signup; get from dashboard or run: npx convex dev)
# If missing, app loads but Convex features (map, search, user signup) will not work.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud/

# Paystack (for Mchango crowdfunding)
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# NextAuth (required for login; generate secret: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Admin login — password must be hashed with bcrypt (never put plain password here)
# Example: email admin@cfwt.com, password Admin123! (hash below). For production run: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_EMAIL=admin@cfwt.com
ADMIN_PASSWORD_HASH=$2a$10$tHW7vxh5G56WCos6sI5hkOyqqiIjSdzOcS6jgU6fuZZbttkkkR/uK

# Africa's Talking (for USSD and SMS reporting)
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=your_api_key
