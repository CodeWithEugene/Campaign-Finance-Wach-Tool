rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Report media — public read, authenticated upload via server
    match /reports/{reportId}/{fileName} {
      allow read: if true;
      allow write: if false;  // Firebase Functions handle uploads
    }
    
    // Admin only for other assets
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
